<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include default Spring Boot logging configurations -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <!-- 1. Fetch properties dynamically from application.yml -->
    <springProperty scope="context" name="consolePattern" source="logging.pattern.console" />
    <springProperty scope="context" name="logFile" source="logging.file.name" defaultValue="logs/application.log" />

    <!-- 2. Console Layout -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${consolePattern}</pattern>
        </encoder>
    </appender>

    <!-- 3. File Layout with automatic Daily + Size Rotation -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${logFile}</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Archives files daily, compresses them into .gz, and appends an index counter (%i) -->
            <fileNamePattern>${logFile}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 4. Runtime Binding -->
    <!-- Do not hardcode specific package logger tags here; Spring automatically injects -->
    <!-- your application.yml logging levels right into this root level binder. -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>
